# Базовый URL API. Пусто = относительные пути (перехватываются MSW в dev).
# Для реального бэка укажи, напр. https://api.zorkalogic.com
NEXT_PUBLIC_API_URL=

# Включить моковое API (MSW). true — пока нет бэка; false — когда появится бэк.
NEXT_PUBLIC_USE_MOCKS=true

# Публичный URL сайта (для canonical / OG).
NEXT_PUBLIC_SITE_URL=https://zorkalogic.com

# ID счётчика Яндекс.Метрики (пусто = аналитика выключена).
NEXT_PUBLIC_YM_ID=
